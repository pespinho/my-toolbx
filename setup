#!/usr/bin/env bash

set -e

SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/scripts/setup"

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export REPO_ROOT

CMD="${1:-help}"
shift || true

# Guard against private/internal scripts
if [[ "$CMD" == _* ]]; then
    echo "Unknown command: $CMD" >&2
    exit 1
fi

SCRIPT="$SCRIPTS_DIR/$CMD"

if [[ ! -f "$SCRIPT" ]]; then
    echo "Unknown command: $CMD" >&2
    echo "Run 'setup help' for a list of commands." >&2
    exit 1
fi

# Run the subcommand script from its own directory so relative
# paths (e.g. source ./_common) work correctly
cd "$SCRIPTS_DIR"
exec bash "$CMD" "$@"
